{
  "name": "bughunt",
  "version": "0.1.0",
  "private": true,
  "description": "A daily Wordle-style puzzle: one short function, exactly one planted bug.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/bughunt.git"
  },
  "keywords": [
    "game",
    "puzzle",
    "typescript",
    "wordle-clone",
    "debugging"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "eslint": "^9.39.4",
    "fast-check": "^4.9.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
