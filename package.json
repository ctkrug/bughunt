{
  "name": "bughunt",
  "version": "0.1.0",
  "private": true,
  "description": "A daily Wordle-style puzzle: one short function, exactly one planted bug.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  }
}
